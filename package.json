  "description": "ShotShorts - AI-powered short video generator from long videos with ADHD background footage",
  "scripts": {
    "test": "node --test test/*.test.js",
    "app:start": "npm --workspace app start",
    "app:check-resources": "npm --workspace app run check:resources",
