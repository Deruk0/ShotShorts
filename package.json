    "app:build:portable": "npm --workspace app run build:portable",
    "web:dev": "npm --workspace web run dev",
    "web:build": "npm --workspace web run build",
    "web:lint": "npm --workspace web run lint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Deruk0/ShotShorts.git"
  },
