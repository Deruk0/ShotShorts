{
  "name": "shotshorts",
  "version": "2.0.0",
  "description": "Short video generator from long videos with ADHD background footage",
  "main": "main.js",
  "author": "Deruk0",
  "scripts": {
    "start": "node launch.js",
    "check:resources": "node scripts/validate-build-resources.js --warn-only",
    "prebuild": "node scripts/validate-build-resources.js",
    "prebuild:fast": "node scripts/validate-build-resources.js",
    "build": "electron-builder --dir",
    "build:fast": "electron-builder --dir",
    "build:portable": "electron-builder --win portable"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "electron-store": "^11.0.2",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.5",
    "https-proxy-agent": "^7.0.6",
    "playwright": "^1.49.0",
    "socks-proxy-agent": "^8.0.5"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "electronVersion": "31.7.7",
    "compression": "store",
    "directories": {
      "output": "../Ready_App_EXE"
    },
    "appId": "com.shotshorts.app",
    "productName": "ShotShorts",
    "files": [
      "main.js",
      "preload.js",
      "services/**",
      "renderer/**",
      "icon.png",
      "icon.svg"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ],
      "sign": null,
      "signDlls": false,
      "icon": "icon.png"
    },
    "portable": {
      "artifactName": "${productName} ${version}.${ext}"
    },
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    }
  }
}
